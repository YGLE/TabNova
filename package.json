{
  "name": "tabnova",
  "version": "0.1.0",
  "description": "Web Bookmarks Manager - Revolutionary tab groups management with interactive bubble visualization",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:backend": "vite build --config vite.backend.config.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint extension/src --ext .ts,.tsx",
    "lint:fix": "eslint extension/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"extension/src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.0.0",
    "@fontsource/inter": "^5.0.0",
    "d3": "^7.8.0",
    "idb": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.0",
    "@types/chrome": "^0.0.254",
    "@types/d3": "^7.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.1.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^23.0.0",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-web-extension": "^4.1.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "chrome-extension",
    "bookmarks",
    "tab-groups",
    "visualization",
    "d3js",
    "react"
  ],
  "author": "YGLE",
  "license": "MIT"
}
